{
  "name": "yuketang-auto-answer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "用 Playwright 驱动本机 Chrome，读取雨课堂题目，调用火山方舟大模型作答并自动勾选选项（不自动提交）。",
  "scripts": {
    "start": "node src/cli.mjs",
    "answer": "node src/run.mjs",
    "course": "node src/course.mjs",
    "dry-run": "node src/run.mjs --dry-run",
    "inspect": "node src/inspect.mjs"
  },
  "dependencies": {
    "playwright-core": "^1.49.0"
  }
}
